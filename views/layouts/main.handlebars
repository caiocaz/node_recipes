<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Receitas</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="/css/styles.css" />
    <script src="/js/recipe-ingredients.js" defer></script>
  </head>
  <body>
    <nav id="navbar">
      <a href="/recipes" id="logo">
        <img src="/img/recipes_logo.png" alt="Receitas Culinárias">
        <div class="logo-text"><span>Receitas</span> Culinárias</div>
      </a>
      <ul>
        {{#if session.userId}}
          <div class="welcome-message">
            Bem-vindo, <a href="/profile">{{session.userName}}</a> |
          </div>
          <li><a href="/recipes">Minhas Receitas</a></li>
          <li><a href="/shopping-list">Lista de Compras</a></li>
          <li><a href="/recipes/add">Nova Receita</a></li> 
          <li><a href="/logout">Sair</a></li>
        {{else}}
          <li><a href="/login">Entrar</a></li>
          <li><a href="/register">Registrar</a></li>
        {{/if}}
      </ul>
    </nav>

    <div class="container">
      {{#if messages.message}}
        {{#each messages.message}}
          <div class="message">
            {{this}}
          </div>
        {{/each}}
      {{/if}}
      <div id="global-toast" class="global-toast" aria-live="polite" aria-atomic="true" hidden></div>
      {{{body}}}
    </div>

    <footer>
      <p><span>Receitas</span> &copy; 2026</p>
    </footer>
    <script src="/js/recipe-home-search.js" defer></script>
    <script src="/js/recipe-suggestions.js" defer></script>
    <script>
      // Highlight active navbar link based on current page
      document.addEventListener('DOMContentLoaded', () => {
        const currentPath = window.location.pathname
        const navLinks = document.querySelectorAll('#navbar ul li a')
        
        navLinks.forEach(link => {
          const href = link.getAttribute('href')
          // Exact match for the link
          if (href === currentPath) {
            link.classList.add('active')
          }
        })
      })
    </script>
    <script src="/js/shopping-list.js" defer></script>
  </body>
</html>
